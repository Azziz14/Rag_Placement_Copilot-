# Auto detect text files and perform LF normalization
* text=auto

# Force LF for scripts and source files
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sh text eol=lf

# Binary files — do not attempt to normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.db binary
*.sqlite binary
*.zip binary
*.tar.gz binary
